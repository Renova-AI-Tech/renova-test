{
  "name": "painel-demandas-test",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x || 22.x || 23.x || 24.x || 25.x || 26.x",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "pnpm --filter @painel-demandas/api dev",
    "dev:web": "pnpm --filter @painel-demandas/web dev",
    "seed": "pnpm --filter @painel-demandas/api seed",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm --filter @painel-demandas/web build"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.27.0",
    "globals": "^16.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0",
    "vitest": "^3.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  },
  "packageManager": "pnpm@10.28.0"
}
